# auth-service — copy to .env and adjust.

PORT=8080
HOST_PORT=8001
DEBUG=true

# Postgres (uses its own schema via search_path).
DATABASE_URL=postgres://aifa:aifa@localhost:5432/aifa?sslmode=disable&search_path=auth,public

# Redis — JWT blacklist.
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# NATS — user.provisioned / user.deleted events.
NATS_URL=nats://localhost:4222

# Shared JWT secret — every service validates user tokens with this.
JWT_SECRET=change-me-in-production-min-32-chars-long-secret
JWT_ACCESS_TTL_HOURS=720
JWT_REFRESH_TTL_HOURS=8760

# OAuth.
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=app.aifa.ios
