# ============================================================================
# AIFA — root environment
# Copy to .env and adjust. Nothing should be hardcoded in compose / Dockerfile —
# everything sourced from here.
# ============================================================================

# ---- Domain / gateway ----
DOMAIN=localhost
GATEWAY_HTTP_PORT=8080
TRAEFIK_DASHBOARD_PORT=8090
SWAGGER_UI_PORT=8081

# ---- Postgres ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=aifa
POSTGRES_PASSWORD=aifa
POSTGRES_DB=aifa

# Per-service Postgres schemas (search_path).
SCHEMA_AUTH=auth
SCHEMA_USERS=users
SCHEMA_HABITS=habits
SCHEMA_GOALS=goals
SCHEMA_TASKS=tasks
SCHEMA_FINANCE=finance
SCHEMA_NOTIFICATIONS=notifications

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- NATS ----
NATS_HOST=nats
NATS_CLIENT_PORT=4222
NATS_HTTP_PORT=8222
NATS_URL=nats://nats:4222

# ---- Service-internal listen port (every service binds to this inside its container) ----
SERVICE_PORT=8080

# ---- Service host-side ports (what docker-compose publishes) ----
AUTH_PORT=8001
USER_PORT=8002
HABIT_PORT=8003
GOAL_PORT=8004
TASK_PORT=8005
FINANCE_PORT=8006
AI_PORT=8007
NOTIFICATION_PORT=8008
SCHEDULER_HEALTH_PORT=8009

# ---- Debug ----
DEBUG=true

# ---- Shared JWT (every service validates user tokens with this secret) ----
JWT_SECRET=change-me-in-production-min-32-chars-long-secret
JWT_ACCESS_TTL_HOURS=720
JWT_REFRESH_TTL_HOURS=8760

# ---- Service-to-service auth (e.g. ai-service hitting habit/finance) ----
SERVICE_JWT_SECRET=change-me-service-to-service-shared-secret

# ---- Currency defaults for financial entities ----
DEFAULT_CURRENCY=USD

# ---- Cron schedules (UTC, 5-field) ----
CRON_RECURRING=*/5 * * * *
CRON_REMINDERS=0 9 * * *

# ---- OpenAI (ai-service) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- APNs (notification-service) — leave empty in dev to skip push delivery ----
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=app.aifa.ios
APNS_PRODUCTION=false

# ---- Google OAuth (auth-service) — used to verify the iOS-supplied ID token ----
GOOGLE_CLIENT_ID=

# ---- Apple OAuth (auth-service) ----
APPLE_CLIENT_ID=app.aifa.ios
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
