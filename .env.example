# Server
PORT=8080
DEBUG=true

# Database (app uses DATABASE_URL; POSTGRES_* vars are for docker-compose only)
DATABASE_URL=postgres://habitflow:habitflow@localhost:5432/habitflow?sslmode=disable
POSTGRES_USER=habitflow
POSTGRES_PASSWORD=habitflow
POSTGRES_DB=habitflow
POSTGRES_PORT=5432

# JWT
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_ACCESS_TTL_DAYS=30
JWT_REFRESH_TTL_DAYS=365

# OpenAI (for AI features)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Apple Push Notifications (optional)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=
APNS_BUNDLE_ID=
