# ============================================================================
# AIFA — root infrastructure environment
# Copy to .env and adjust. Each service also has its own .env.example
# inside services/<name>/ with service-specific variables.
# ============================================================================

# ---- Domain / gateway ----
DOMAIN=localhost
TRAEFIK_DASHBOARD_PORT=8090

# ---- Postgres ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=aifa
POSTGRES_PASSWORD=aifa
POSTGRES_DB=aifa

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- NATS ----
NATS_URL=nats://nats:4222

# ---- Shared JWT (all services validate with this secret) ----
JWT_SECRET=change-me-in-production-min-32-chars-long-secret
JWT_ACCESS_TTL_HOURS=720
JWT_REFRESH_TTL_HOURS=8760

# ---- Service-to-service auth (ai-service calling finance/habit/...) ----
SERVICE_JWT_SECRET=change-me-service-to-service-shared-secret

# ---- External integrations ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# APNS (notification-service) — mount key file via volume
APNS_KEY_PATH=/secrets/apns.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=app.aifa.ios
APNS_PRODUCTION=false

# Google OAuth (auth-service) — client ID used for ID-token audience check
GOOGLE_CLIENT_ID=

# Apple OAuth (auth-service)
APPLE_CLIENT_ID=app.aifa.ios
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=/secrets/apple.p8
